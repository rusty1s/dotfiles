[user]
  name=rusty1s
  email=matthias.fey@tu-dortmund.de

[github]
  user=rusty1s

[push]
  default=simple
  autoSetupRemote=true

[core]
  excludesfile=$HOME/.gitignore
  pager=delta

[interactive]
  diffFilter=delta --color-only

[delta]
  navigate=true
  light=true
  side-by-side=true
  syntax-theme=GitHub

[merge]
  conflictStyle=zdiff3
